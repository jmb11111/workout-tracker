# Database
DB_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://workout:change-me-strong-password@db:5432/workout_tracker

# App secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-generate-a-real-secret

# Authentik OIDC
OIDC_ISSUER_URL=https://auth.yourdomain.com/application/o/workout-tracker/
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=https://workout.yourdomain.com/auth/callback

# Ollama (on a separate machine — set to the IP/hostname of your Ollama server)
OLLAMA_URL=http://10.10.10.55:11434
OLLAMA_MODEL=qwen2.5:7b

# Claude API (fallback parser — optional)
ANTHROPIC_API_KEY=sk-ant-...

# Webhook for parse failure alerts (optional — e.g. Discord, ntfy, Gotify)
ALERT_WEBHOOK_URL=

# Scraper schedule (cron format, default 5am daily)
SCRAPER_CRON=0 5 * * *

# Base URL of this application
BASE_URL=https://workout.yourdomain.com
